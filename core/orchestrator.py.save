	        import vertexai
	from vertexai.generative_models import GenerativeModel
	
	vertexai.init()
	
	model = GenerativeModel("gemini-pro")
	
	class GeminiClient:
	    def __init__(self, model):
	        self.model = model
	
	    def generate(self, prompt, data):
	        response = self.model.generate_content(
	            f"{prompt}\n\nDATA:\n{data}"
	        )
