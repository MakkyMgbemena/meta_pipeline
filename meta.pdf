import markdown
from weasyprint import HTML

# I put your exact file path here, using double backslashes for Windows
file_path = "C:\\Users\\annas\\OneDrive\\Desktop\\Meta_Pipeline_Whitepaper.txt"

with open(file_path, "r", encoding="utf-8") as f:
    text_content = f.read()

html_content = markdown.markdown(text_content)

styled_html = f"""
<html><head>
  <title>Unified AI Meta Pipeline — Technical Whitepaper</title>
  <style>
    body {{ font-family: Calibri, sans-serif; margin: 40px; line-height: 1.6; color: #333; }}
    h1 {{ color: #1a1a2e; font-size: 24pt; text-align: center; }}
    h2 {{ color: #16213e; border-bottom: 1px solid #ccc; padding-bottom: 5px; margin-top: 30px; }}
    h3 {{ color: #1a1a2e; }}
    pre {{ background: #f4f4f4; padding: 15px; border-radius: 5px; font-family: monospace; white-space: pre-wrap; font-size: 10pt; }}
    table {{ border-collapse: collapse; width: 100%; margin-top: 15px; }}
    th, td {{ border: 1px solid #ddd; padding: 8px; text-align: left; }}
    th {{ background: #1a1a2e; color: white; }}
  </style>
</head><body>
{html_content}
</body></html>
"""

try:
    print("Generating PDF...")
    # This will save the PDF directly to your Desktop
    output_path = "C:\\Users\\annas\\OneDrive\\Desktop\\Meta_Pipeline_Whitepaper.pdf"
    HTML(string=styled_html).write_pdf(output_path)
    print(f"Success! Your PDF is ready at: {output_path}")
except Exception as e:
    print(f"An error occurred: {e}")